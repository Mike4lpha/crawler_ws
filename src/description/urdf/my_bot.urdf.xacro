  </link>
  <!-- Joint from base_link to 6in_wheel_4 -->
  <joint name="bl" type="continuous">
    <origin xyz="-0.1051 0.1095 0.0275" rpy="-1.5708 0 -0"/>
    <parent link="base_link"/>
    <child link="6in_wheel_4"/>
    <axis xyz="0 0 1"/>
    <limit effort="50" velocity="10" lower="-3.141592653589793" upper="3.141592653589793"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>
  <!-- Link pan_and_tilt -->
  <link name="pan_and_tilt">
    <inertial>
      <origin xyz="0.0169854 0.000962923 -0.0137749" rpy="0 0 0"/>
      <mass value="0.0931715"/>
      <inertia ixx="2.17613e-05" ixy="1.04498e-06" ixz="1.91243e-06" iyy="2.26582e-05" iyz="-5.98382e-07" izz="2.66699e-05"/>
    </inertial>
    <!-- Part pan_and_tilt -->
    <visual>
      <origin xyz="-0.0875 0.000494185 -0.0708" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="file://$(find description)/meshes/pan_and_tilt.stl"/>
      </geometry>
      <material name="pan_and_tilt_material">
        <color rgba="0.917647 0.917647 0.917647 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.0875 0.000494185 -0.0708" rpy="0 -0 0"/>
      <geometry>
        <mesh filename="file://$(find description)/meshes/pan_and_tilt.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint from base_link to pan_and_tilt -->
  <joint name="pan" type="revolute">
    <origin xyz="0.0875 -0.000494185 0.0668" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="pan_and_tilt"/>
    <axis xyz="0 0 -1"/>
    <limit effort="10" velocity="2" lower="-0.52" upper="0.52"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <box size="0.01 0.03 0.03" />
      </geometry>
      <material name="camera_link">
        <color rgba="0.231373 0.380392 0.705882 1"/>
      </material>
    </visual>
  </link>

  <!-- Camera mounted on pan-tilt -->
  <joint name="camera_joint" type="fixed">
    <parent link="pan_and_tilt"/>
    <child link="camera_link"/>

    <!-- Adjust these values to place camera correctly -->
    <origin xyz="0.035 0.0 -0.015" rpy="0 0 0"/>
  </joint>

  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <link name="light_fl">
    <visual>
      <geometry>
        <box size="0.02 0.002 0.02"/>
      </geometry>
      <material name="led_white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
  </link>

  <link name="light_fr">
    <visual>
      <geometry>
        <box size="0.02 0.002 0.02"/>
      </geometry>
      <material name="led_white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
  </link>

  <link name="light_bl">
    <visual>
      <geometry>
        <box size="0.02 0.002 0.02"/>
      </geometry>
      <material name="led_white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
  </link>

  <link name="light_br">
    <visual>
      <geometry>
        <box size="0.02 0.002 0.02"/>
      </geometry>
      <material name="led_white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
  </link>

  <!-- Link face_plate -->
  <link name="face_plate">
    <inertial>
      <origin xyz="5.2197e-08 0.0057711 -0.00161" rpy="0 0 0"/>
      <mass value="0.0382468"/>
      <inertia ixx="3.77276e-05" ixy="1.53e-10" ixz="-9e-12" iyy="6.16865e-05" iyz="-5.5269e-08" izz="9.9359e-05"/>
    </inertial>
    <!-- Part face_plate -->
    <visual>
      <origin xyz="0 -0.05095 -0.13" rpy="-1.5708 -1.5708 0"/>
      <geometry>
        <mesh filename="file://$(find description)/meshes/face_plate.stl"/>
      </geometry>
      <material name="face_plate_material">
        <color rgba="0.231373 0.380392 0.705882 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 -0.05095 -0.13" rpy="-1.5708 -1.5708 0"/>
      <geometry>
        <mesh filename="file://$(find description)/meshes/face_plate.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Front Left -->
  <joint name="light_fl_joint" type="fixed">
    <parent link="face_plate"/>
    <child link="light_fl"/>
    <origin xyz="0.047 0.04 0.0" rpy="1.57 0 0"/>
  </joint>

  <!-- Front Right -->
  <joint name="light_fr_joint" type="fixed">
    <parent link="face_plate"/>
    <child link="light_fr"/>
    <origin xyz="-0.047 0.04 0.0" rpy="1.57 0 0"/>
  </joint>

  <!-- Bottom Left -->
  <joint name="light_bl_joint" type="fixed">
    <parent link="face_plate"/>
    <child link="light_bl"/>
    <origin xyz="0.047 -0.035 0.0" rpy="1.57 0 0"/>
  </joint>

  <!-- Bottom Right -->
  <joint name="light_br_joint" type="fixed">
    <parent link="face_plate"/>
    <child link="light_br"/>
    <origin xyz="-0.047 -0.035 0.0" rpy="1.57 0 0"/>
  </joint>

  <!-- Joint from base_link to face_plate -->
  <joint name="face_plate_joint" type="fixed">
    <origin xyz="0.13 0.000319729 0.0506946" rpy="1.5708 -0 1.5708"/>
    <parent link="base_link"/>
    <child link="face_plate"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10"/>
  </joint>
</robot>
